{
    "command": [
        "/mnt/sdb/projects/ensembl-vep/vep",
        "--format", "vcf",
        "__OUTPUT_FORMAT_FLAG__",
        "--fasta", "/mnt/sdb/VEP/ref_fasta/ucsc.hg19.fasta",
        "--dir_cache", "/mnt/sdb/VEP/VEP_cache/",
        "--dir_plugins", "/mnt/sdb/gvcf_ustina/testing/clingen-cohort-vds-browser/Plugins",
        "--no_stats",
        "--cache",
        "--offline",
        "--assembly", "GRCh37",
        "--cache_version", "108",
        "--merged",
        "--hgvs",
        "--hgvsg",
        "--symbol",
        "--pick",
        "--canonical",
        "--use_given_ref",
        "--plugin", "CADD,snv=https://krishna.gs.washington.edu/download/CADD/v1.4/GRCh37/whole_genome_SNVs_inclAnno.tsv.gz,indels=https://krishna.gs.washington.edu/download/CADD/v1.4/GRCh37/InDels.tsv.gz",
        "--custom", "/mnt/sdb/gvcf_ustina/testing/clingen-cohort-vds-browser/Plugins/clinvar.vcf.gz,ClinVar,vcf,exact,0,CLNSIG,CLNREVSTAT",
        "-o", "STDOUT"
    ],
    "env": {
        "PERL5LIB": "/mnt/sdb/gvcf_ustina/testing/clingen-cohort-vds-browser/Plugins"
    },
    "vep_json_schema": "Struct{input:String,most_severe_consequence:String,transcript_consequences:Array[Struct{consequence_terms:Array[String],impact:String,gene_symbol:String,hgvsg:String,hgvsc:String,hgvsp:String,transcript_id:String,cadd_phred:Float64,cadd_raw_rankscore:Float64,canonical:Int32}],intergenic_consequences:Array[Struct{consequence_terms:Array[String],impact:String}],custom_annotations:Struct{ClinVar:Array[Struct{allele:String,fields:Struct{CLNSIG:String,CLNREVSTAT:String}}]}}"
}
